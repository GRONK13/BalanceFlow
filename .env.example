# =========================================================================
# BalanceFlow Environment Configurations Template (.env.example)
# Rename this file to '.env' and fill in your real credentials.
# =========================================================================

# Database Connection (PostgreSQL connection string formatted for ADO.NET)
ConnectionStrings__DefaultConnection="Host=YOUR_POSTGRES_HOST;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Port=5432;SSL Mode=Require;Trust Server Certificate=true;Max Auto Prepare=0;Pooling=false;"

# JWT Security Configurations (Secret MUST be at least 32 characters long)
Jwt__Secret="YOUR_SUPER_SECRET_SIGNING_KEY_MUST_BE_AT_LEAST_32_CHARACTERS"
Jwt__Issuer="BalanceFlowIdentityServer"
Jwt__Audience="BalanceFlowApi"

# Allowed CORS Origins (Comma-separated for multiple origins, e.g. http://localhost:3000,https://app.vercel.app)
AllowedOrigins="http://localhost:3000"

# Next.js Frontend configurations (API Gateway Endpoint URL)
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
